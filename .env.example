ANTHROPIC_API_KEY=sk-ant-...
# Banco fora do OneDrive para evitar conflito de sync
DATABASE_URL=sqlite:///C:/stoa-civil/stoa_civil.db
PORT=8100
# Habilita endpoints de diagnostico (ex: /api/projects/debug-db). Deixe desligado em producao.
ENABLE_DEBUG_ENDPOINTS=false
# Restringe CORS a dominios especificos (separados por virgula). Vazio = libera geral (padrao atual).
CORS_ORIGINS=

# ── Autenticacao (Supabase Auth) ──
# AUTH_ENABLED=false desliga a exigencia de login (use so em dev/emergencia)
AUTH_ENABLED=true
# URL do projeto Supabase (JWKS e buscado daqui; tem default no codigo)
SUPABASE_URL=https://ankrlomafgitalnbfhlk.supabase.co
# Emails autorizados a acessar o app (separados por virgula).
# Sem allowlist, qualquer pessoa que criasse conta teria acesso aos dados.
ALLOWED_EMAILS=ernanefideles22@gmail.com
